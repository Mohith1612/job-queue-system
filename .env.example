# Database
DATABASE_URL=postgresql+asyncpg://jobqueue:jobqueue@localhost:5432/jobqueue

# Redis
REDIS_URL=redis://localhost:6379/0

# App
LOG_LEVEL=INFO
WORKER_CONCURRENCY=4
JOB_MAX_EXECUTION_SECONDS=300
RECOVERY_STUCK_THRESHOLD_MINUTES=10

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
