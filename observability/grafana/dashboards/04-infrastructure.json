{
  "title": "Infrastructure (DB, Redis, Containers)",
  "uid": "jq-infrastructure",
  "tags": ["job-queue"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "DB Query Duration P95 by Operation",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(jobqueue_db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "{{ operation }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 2,
      "title": "DB Connection Pool",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (state) (jobqueue_db_pool_size_total)",
          "legendFormat": "{{ state }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 3,
      "title": "DB Pool Utilization %",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(jobqueue_db_pool_size_total{state=\"checked_out\"}) / 30",
          "legendFormat": "utilization"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "DB Errors",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 8, "w": 9, "h": 6 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (error_type) (rate(jobqueue_db_errors_total[5m]))",
          "legendFormat": "{{ error_type }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    },
    {
      "id": 5,
      "title": "Redis Command Latency P99",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, command) (rate(jobqueue_redis_command_duration_seconds_bucket[5m])))",
          "legendFormat": "{{ command }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "title": "Redis Pool Connections",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (state) (jobqueue_redis_pool_connections_total)",
          "legendFormat": "{{ state }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 7,
      "title": "OTel Collector Spans Received / Exported",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 6 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(otelcol_receiver_accepted_spans[5m])",
          "legendFormat": "received"
        },
        {
          "expr": "rate(otelcol_exporter_sent_spans[5m])",
          "legendFormat": "exported to Tempo"
        },
        {
          "expr": "rate(otelcol_exporter_send_failed_spans[5m])",
          "legendFormat": "export failures"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    }
  ]
}
