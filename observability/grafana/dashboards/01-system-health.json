{
  "title": "System Health Overview",
  "uid": "jq-system-health",
  "tags": ["job-queue"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "API Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (http_response_status_code) (rate(http_server_request_duration_seconds_count[5m]))",
          "legendFormat": "{{ http_response_status_code }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2,
      "title": "API P95 Latency by Route",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{ http_route }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 3,
      "title": "API Error Rate",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[5m])) / sum(rate(http_server_request_duration_seconds_count[5m]))",
          "legendFormat": "Error Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Queue Depths",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "jobqueue_queue_depth",
          "legendFormat": "{{ queue_name }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 5,
      "title": "Jobs Created vs Completed (rate/min)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(jobqueue_jobs_created_total[5m])) * 60",
          "legendFormat": "created"
        },
        {
          "expr": "sum(rate(jobqueue_jobs_completed_total[5m])) * 60",
          "legendFormat": "completed"
        },
        {
          "expr": "sum(rate(jobqueue_jobs_failed_total[5m])) * 60",
          "legendFormat": "failed"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "title": "Active Jobs",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 6 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        { "expr": "sum(jobqueue_jobs_active)", "legendFormat": "Active" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 7,
      "title": "DB Pool Utilization",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 6 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(jobqueue_db_pool_size_total{state=\"checked_out\"}) / 30",
          "legendFormat": "Pool used"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Worker Restarts (24h)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 6 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(jobqueue_worker_restarts_total[24h]))",
          "legendFormat": "Restarts"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 4 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Retry Queue Size",
      "type": "stat",
      "gridPos": { "x": 18, "y": 16, "w": 6, "h": 6 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "jobqueue_queue_depth{queue_name=\"retry\"}",
          "legendFormat": "Retry queue"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    }
  ]
}
